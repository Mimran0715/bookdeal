# TinyFish API key
TINYFISH_API_KEY="your_tinyfish_key_here"

# Required for Pydantic AI agent mode with the default Gemini model.
GEMINI_API_KEY="your_gemini_key_here"

# Optional agent settings.
BOOKDEAL_MODEL="google-gla:gemini-2.5-flash"
BOOKDEAL_LOGFIRE="0"

# Optional Logfire tracing.
# You can use `logfire auth` instead of setting this manually.
LOGFIRE_TOKEN="your_logfire_write_token_here"
